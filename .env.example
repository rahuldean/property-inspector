# Required for local dev - set the master key to access local LiteLLM admin UI
LITELLM_MASTER_KEY=sk-change-me

# Cloudflare Access credentials for aigw.labmox.com (required when LITELLM_URL points to aigw)
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Optional
# API_PORT=6000
# LITELLM_PORT=4000
# LITELLM_MODEL=inspector
# LITELLM_API_KEY=
# LITELLM_URL=https://aigw.labmox.com  # defaults to http://localhost:4000 for local dev
# MAX_UPLOAD_MB=32

# LiteLLM Postgres (local dev only)
# LITELLM_DB_NAME=
# LITELLM_DB_USER=
# LITELLM_DB_PASSWORD=
